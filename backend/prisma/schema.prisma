}

model GameSession {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  user             UserProfile @relation(fields: [userId], references: [userId])
  gameType         String      @default("bubble_shooter") @map("game_type")
  score            Int         @default(0)
  livesUsed        Int         @default(1) @map("lives_used")
  retriesWithVideo Int         @default(0) @map("retries_with_video")
  retriesWithWait  Int         @default(0) @map("retries_with_wait")
  coinsEarned      Int         @default(0) @map("coins_earned")
  lastGameOverAt   DateTime?   @map("last_game_over_at")
  completedAt      DateTime?   @map("completed_at")
  createdAt        DateTime    @default(now()) @map("created_at")

  adViews AdView[]

  @@index([userId])
  @@index([createdAt])
  @@map("game_sessions")
}

model Referral {
  id            String      @id @default(uuid())
  referrerId    String      @map("referrer_id")
  referrer      UserProfile @relation("Referrer", fields: [referrerId], references: [userId])
  refereeId     String      @map("referee_id")
  referee       UserProfile @relation("Referee", fields: [refereeId], references: [userId])
  referralCode  String      @unique @map("referral_code")
  status        String      @default("pending")
  qualifiedAt   DateTime?   @map("qualified_at")
  paidAt        DateTime?   @map("paid_at")
  bonusCoins    Int         @default(1000) @map("bonus_coins")
  bonusValueZar Decimal     @default(10.00) @map("bonus_value_zar") @db.Decimal(10, 4)
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([referrerId])
  @@index([refereeId])
  @@index([status])
  @@map("referrals")
}

model SignupBonus {
  id                 Int         @id @default(autoincrement())
  userId             String      @unique @map("user_id")
  user               UserProfile @relation(fields: [userId], references: [userId])
  countryCode        String      @map("country_code")
  userNumberInRegion Int         @map("user_number_in_region")
  bonusCoins         Int         @default(500) @map("bonus_coins")
  bonusValueZar      Decimal     @default(50.00) @map("bonus_value_zar") @db.Decimal(10, 4)
  eligible           Boolean     @default(true)
  creditedAt         DateTime?   @map("credited_at")
  createdAt          DateTime    @default(now()) @map("created_at")

  @@index([countryCode])
  @@index([eligible])
  @@map("signup_bonuses")
}

model MonthlyLeaderboardAward {
  id          Int         @id @default(autoincrement())
  month       String      @db.VarChar(7)
  userId      String      @map("user_id")
  user        UserProfile @relation(fields: [userId], references: [userId])
  rank        Int
  coinsAwarded Int        @map("coins_awarded")
  awardedAt   DateTime    @default(now()) @map("awarded_at")

  @@unique([month, userId])
  @@index([month])
  @@index([userId])
  @@map("monthly_leaderboard_awards")
}

model Notification {
  id     Int               @id @default(autoincrement())
  event  NotificationEvent
  data   Json
  sentTo String[]          @map("sent_to")
  sentAt DateTime          @default(now()) @map("sent_at")

  @@index([event])
  @@index([sentAt])
  @@map("notifications")
}


// ─── V2 Data Ownership: Ledger Source-of-Truth ────────────────────────────────
// Rules:
//   1. Balance is computed from v2_ledger_entries as SUM(amount_coins) where
//      positive values are credits and negative values are debits.
//      No direct "set balance" writes are permitted in V2.
//   2. Every credit entry MUST carry a unique idempotency_key (provider event id
//      or admin action id). Duplicate keys are rejected by the DB unique index,
//      preventing double-credits on replay.
//   3. A V2Claim starts in status=PENDING. Fulfillment creates a REDEEM entry
//      (negative amountCoins) and transitions the claim to status=FULFILLED.
//   4. These tables are strictly V2-only; V2 code NEVER writes to V1 tables
//      (user_profiles, transactions, ad_views, withdrawals, etc.).
// ──────────────────────────────────────────────────────────────────────────────

model V2LedgerEntry {
  id             Int                @id @default(autoincrement())
  userId         String             @map("user_id")
  /// Purpose of the entry. REDEEM entries have negative amountCoins (debit);
  /// all other types have positive amountCoins (credit).
  type           V2LedgerEntryType  @map("type")
  /// Signed coin amount: positive = credit, negative = debit.
  amountCoins    BigInt             @map("amount_coins")
  description    String?
  /// Required for credits. Uniqueness enforces idempotency: replaying the same
  /// provider event id / admin action id is safely ignored by the caller.
  idempotencyKey String?            @unique @map("idempotency_key")
  metadata       Json?
  /// e.g. admob impression id, admin_action id, v2_claim id
  referenceId    String?            @map("reference_id")
  /// e.g. 'ad_view', 'admin_adjustment', 'claim_fulfillment'
  referenceType  String?            @map("reference_type")
  claimId        Int?               @map("claim_id")
  claim          V2Claim?           @relation(fields: [claimId], references: [id])
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([userId])
  @@index([referenceId])
  @@index([claimId])
  @@index([createdAt])
  @@map("v2_ledger_entries")
}

model V2Reward {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  costCoins   Int       @map("cost_coins")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  claims      V2Claim[]

  @@map("v2_rewards")
}

model V2Claim {
  id             Int           @id @default(autoincrement())
  userId         String        @map("user_id")
  rewardId       Int?          @map("reward_id")
  reward         V2Reward?     @relation(fields: [rewardId], references: [id])
  /// Lifecycle: PENDING → APPROVED → FULFILLED, or PENDING → REJECTED / CANCELED.
  status         V2ClaimStatus @default(PENDING)
  amountCoins    BigInt        @map("amount_coins")
  description    String?
  metadata       Json?
  requestedAt    DateTime      @default(now()) @map("requested_at")
  fulfilledAt    DateTime?     @map("fulfilled_at")
  fulfillmentRef String?       @map("fulfillment_ref")
  notes          String?

  ledgerEntries  V2LedgerEntry[]

  @@index([userId])
  @@index([status])
  @@map("v2_claims")
}

model V2Task {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  type          String    // "survey", "offer", "game", "affiliate"
  provider      String    // "ayet", "wannads", "internal"
  geoCountries  String[]  @map("geo_countries") // ["US", "ZA", "GB"]
  baseRewardUSD Float     @map("base_reward_usd")
  rewardCoins   Int       @map("reward_coins")
  isActive      Boolean   @default(true) @map("is_active")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  completions   V2TaskCompletion[]

  @@index([isActive])
  @@index([provider])
  @@map("v2_tasks")
}

model V2TaskCompletion {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  taskId            Int       @map("task_id")
  task              V2Task    @relation(fields: [taskId], references: [id])
  status            String    @default("pending") // "pending", "approved", "rejected"
  providerReference String?   @map("provider_reference") // Provider's transaction ID
  revenueEarnedUSD  Float?    @map("revenue_earned_usd")
  coinsAwarded      Int       @default(0) @map("coins_awarded")
  approvedAt        DateTime? @map("approved_at")
  rejectedAt        DateTime? @map("rejected_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([userId, taskId]) // Prevent duplicate completions
  @@index([userId])
  @@index([taskId])
  @@index([status])
  @@map("v2_task_completions")
}
